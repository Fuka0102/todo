
<%= form_for(@task) do |f| %>
  <div class='field'>
    <%= f.label :title %><br>
    <%= f.text_field :title %>
  </div>
  <div class='field'>
    <%= f.label :content %><br>
    <%= f.text_field :content %>
  </div>
  <div class='field'>
    <%= f.date_select :deadline %>
  </div>
  <div class='actions'>
    <%= f.submit %>
  </div>
<% end %>

<%= link_to 'Back', tasks_path %>
