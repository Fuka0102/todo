<h1>タスク一覧</h1>

<table>
  <thead>
    <tr>
      <th>タスク名</th>
      <th>説明</th>
    </tr>
  </thead>

  <tbody>
    <% @tasks.each do |task| %>
    <tr>
      <td><%= link_to(task.title,"/tasks/show/#{@tasks.id}" %></td>
      <td><%= task.content %></td>
    </tr>
    <% end %>
  </tbody>
</table>

<%= link_to 'New', new_task_path %>